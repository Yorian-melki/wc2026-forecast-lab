# Secrets — never commit (project holds 5 live API keys)
.env
.env.*
!.env.example
*.secret
secrets/

# Raw API responses may contain account-bound identifiers
data/raw/provider_responses/

# Audit JSON/CSV may contain masked key fragments (first6..last6) — exclude from any
